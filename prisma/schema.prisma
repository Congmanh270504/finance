generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ShareStrategy {
  EQUAL
  CUSTOM
}

enum BalanceLedgerHistoryType {
  EXPENSE_SHARE
  EXPENSE_DELETION_REVERSAL
  SETTLEMENT_PAYMENT
  MANUAL_ADJUSTMENT
}

enum NotificationType {
  EXPENSE_CREATED
}

model Group {
  id                     String                 @id @default(auto()) @map("_id") @db.ObjectId
  name                   String
  currency               String                 @default("VND")
  order                  Int?                   @default(0)
  imgUrl                 String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  User_Groups            User_Groups[]
  Expenses               Expense[]
  Settlements            Settlement[]
  BalanceLedgers         BalanceLedger[]
  BalanceLedgerHistories BalanceLedgerHistory[]
  Notifications          Notification[]

  @@index([createdAt(sort: Desc)])
  @@index([order])
}

model User_Groups {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  groupId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model User {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  email                String                 @unique
  nickname             String?
  passwordHash         String?
  phone                String?
  address              String?
  bio                  String?
  imgUrl               String?
  username             String?
  pronouns             String?
  profileUrl           String?
  company              String?
  location             String?
  avatarTone           String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  User_Groups          User_Groups[]
  paidExpenses         Expense[]              @relation("ExpensePaidBy")
  splitShares          SplitShare[]           @relation("SplitShareMember")
  outgoingSettlements  Settlement[]           @relation("SettlementFrom")
  incomingSettlements  Settlement[]           @relation("SettlementTo")
  debts                BalanceLedger[]        @relation("LedgerFrom")
  credits              BalanceLedger[]        @relation("LedgerTo")
  ledgerHistoryDebts   BalanceLedgerHistory[] @relation("LedgerHistoryFrom")
  ledgerHistoryCredits BalanceLedgerHistory[] @relation("LedgerHistoryTo")
  notifications        Notification[]          @relation("UserNotifications")

  @@index([isActive])
}

model Expense {
  id                     String                 @id @default(auto()) @map("_id") @db.ObjectId
  groupId                String                 @db.ObjectId
  paidByMemberId         String                 @db.ObjectId
  title                  String
  amount                 Int
  shareStrategy          ShareStrategy          @default(EQUAL)
  notes                  String?
  occurredAt             DateTime               @default(now())
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  group                  Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy                 User                   @relation("ExpensePaidBy", fields: [paidByMemberId], references: [id], onDelete: Restrict)
  splitShares            SplitShare[]
  ledgerEntries          BalanceLedger[]
  balanceLedgerHistories BalanceLedgerHistory[] @relation("BalanceLedgerHistoryExpense")
  notifications          Notification[]          @relation("ExpenseNotifications")

  @@index([groupId, occurredAt(sort: Desc)])
  @@index([paidByMemberId, occurredAt(sort: Desc)])
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  groupId   String?          @db.ObjectId
  expenseId String?          @db.ObjectId
  type      NotificationType @default(EXPENSE_CREATED)
  title     String
  message   String
  href      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  group     Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  expense   Expense?         @relation("ExpenseNotifications", fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([expenseId])
}

model SplitShare {
  id                     String                 @id @default(auto()) @map("_id") @db.ObjectId
  expenseId              String                 @db.ObjectId
  memberId               String                 @db.ObjectId
  shareAmount            Int
  createdAt              DateTime               @default(now())
  expense                Expense                @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member                 User                   @relation("SplitShareMember", fields: [memberId], references: [id], onDelete: Restrict)
  balanceLedgerHistories BalanceLedgerHistory[] @relation("BalanceLedgerHistorySplitShare")

  @@unique([expenseId, memberId])
  @@index([memberId, createdAt(sort: Desc)])
}

model Settlement {
  id                     String                 @id @default(auto()) @map("_id") @db.ObjectId
  groupId                String                 @db.ObjectId
  fromMemberId           String                 @db.ObjectId
  toMemberId             String                 @db.ObjectId
  amount                 Int
  note                   String?
  settledAt              DateTime               @default(now())
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  group                  Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromMember             User                   @relation("SettlementFrom", fields: [fromMemberId], references: [id], onDelete: Restrict)
  toMember               User                   @relation("SettlementTo", fields: [toMemberId], references: [id], onDelete: Restrict)
  balanceLedgerHistories BalanceLedgerHistory[] @relation("BalanceLedgerHistorySettlement")

  @@index([groupId, settledAt(sort: Desc)])
}

model BalanceLedger {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId         String   @db.ObjectId
  fromMemberId    String   @db.ObjectId
  toMemberId      String   @db.ObjectId
  amount          Int
  sourceExpenseId String?  @db.ObjectId
  lastComputedAt  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromMember      User     @relation("LedgerFrom", fields: [fromMemberId], references: [id], onDelete: Restrict)
  toMember        User     @relation("LedgerTo", fields: [toMemberId], references: [id], onDelete: Restrict)
  sourceExpense   Expense? @relation(fields: [sourceExpenseId], references: [id], onDelete: SetNull)

  @@unique([groupId, fromMemberId, toMemberId], map: "group_from_to_unique")
  @@index([groupId, amount(sort: Desc)])
  @@index([fromMemberId, toMemberId])
}

model BalanceLedgerHistory {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  groupId                String                   @db.ObjectId
  fromMemberId           String                   @db.ObjectId
  toMemberId             String                   @db.ObjectId
  deltaAmount            Int
  type                   BalanceLedgerHistoryType
  note                   String?
  sourceExpenseId        String?                  @db.ObjectId
  sourceSettlementId     String?                  @db.ObjectId
  sourceSplitShareId     String?                  @db.ObjectId
  sourceExpenseTitle     String?
  fromMemberNameSnapshot String
  toMemberNameSnapshot   String
  occurredAt             DateTime                 @default(now())
  createdAt              DateTime                 @default(now())
  group                  Group                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromMember             User                     @relation("LedgerHistoryFrom", fields: [fromMemberId], references: [id], onDelete: Restrict)
  toMember               User                     @relation("LedgerHistoryTo", fields: [toMemberId], references: [id], onDelete: Restrict)
  sourceExpense          Expense?                 @relation("BalanceLedgerHistoryExpense", fields: [sourceExpenseId], references: [id], onDelete: SetNull)
  sourceSettlement       Settlement?              @relation("BalanceLedgerHistorySettlement", fields: [sourceSettlementId], references: [id], onDelete: SetNull)
  sourceSplitShare       SplitShare?              @relation("BalanceLedgerHistorySplitShare", fields: [sourceSplitShareId], references: [id], onDelete: SetNull)

  @@index([groupId, occurredAt(sort: Desc)])
  @@index([groupId, fromMemberId, toMemberId, occurredAt(sort: Desc)])
  @@index([groupId, type, occurredAt(sort: Desc)])
  @@index([sourceExpenseId])
  @@index([sourceSettlementId])
}
